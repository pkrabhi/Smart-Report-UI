# KMC Smart Query UI — Environment Variables
# Copy this file to .env and update values

# API base path (used with Vite proxy — no need to change for local dev)
VITE_API_BASE=/api/smart-query

# Backend service host and port (used in vite.config.js proxy)
VITE_SERVICE_HOST=localhost
VITE_SERVICE_PORT=8101

# For direct URL (without proxy), use:
# VITE_API_BASE=http://192.168.0.132:8101/smart-query-service/api/smart-query
